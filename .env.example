# =============================================================================
# Jarvis — Configuração Local
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
# =============================================================================

# --- Geral ---
JARVIS_ENV=development
JARVIS_LOG_LEVEL=DEBUG

# --- PostgreSQL ---
JARVIS_DB_HOST=localhost
JARVIS_DB_PORT=5432
JARVIS_DB_USER=postgres
JARVIS_DB_PASSWORD=postgres
JARVIS_DB_NAME=jarvis_kb

# --- Modelos ---
# Caminho para o modelo GGUF do LLM (relativo à raiz do projeto ou absoluto)
JARVIS_LLM_MODEL_PATH=models/mistral-7b-instruct-v0.3.Q4_K_M.gguf
JARVIS_LLM_N_GPU_LAYERS=-1
JARVIS_LLM_N_CTX=4096

# Modelo de embeddings (será baixado automaticamente pelo sentence-transformers)
JARVIS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Modelo STT (Faster Whisper - use deepdml/faster-whisper-large-v3-turbo-ct2 para melhor performance bilíngue)
JARVIS_STT_MODEL_SIZE=deepdml/faster-whisper-large-v3-turbo-ct2
JARVIS_STT_COMPUTE_TYPE=float16
JARVIS_STT_DEVICE=cuda

# --- TTS (Text-to-Speech) ---
JARVIS_TTS_ENABLED=True
JARVIS_TTS_EN_MODEL_NAME=en_GB-alan-medium.onnx
JARVIS_TTS_EN_BASE_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_GB/alan/medium
JARVIS_TTS_LENGTH_SCALE=0.80

# --- Áudio ---
JARVIS_AUDIO_SAMPLE_RATE=16000
JARVIS_AUDIO_CHANNELS=1
JARVIS_AUDIO_VAD_AGGRESSIVENESS=2

# --- ChromaDB ---
JARVIS_CHROMA_PERSIST_DIR=data/chroma

# --- Interface ---
# Opções: terminal, web
JARVIS_UI_MODE=terminal
JARVIS_WEB_HOST=127.0.0.1
JARVIS_WEB_PORT=8000

# --- Integração com Home Assistant OS ---
JARVIS_HA_URL=http://homeassistant.local:8123/api
